                    </div>`
                  : config.singleEvidence
                  ? `<div class="evidence-upload-grid single-evidence-grid">
                      <label>${config.evidenceLabel} <input type="file" id="${config.type}-evidence" data-${config.type}-evidence accept="image/*"></label>
                    </div>`
                  : `<div class="evidence-upload-grid">
                      <label>${config.firstEvidenceLabel} <input type="file" id="first-${config.type}-evidence" data-${config.type}-evidence accept="image/*"></label>
                      <label>${config.lastEvidenceLabel} <input type="file" id="last-${config.type}-evidence" data-${config.type}-evidence accept="image/*"></label>
                    </div>`
              }
            `
            : ""
        }

        <div class="signature-grid label-signoff-grid">
          <label>${config.signedByLabel} <input value="${currentLogin ? currentLogin.user : stage.user}" readonly></label>
          <label>Date / Time <input value="${record.printedAt || "Pending print"}" readonly></label>
          <div class="signoff-action">
            <button class="classic-button primary" type="button" id="${config.type}-complete-button" disabled>Submit / User Sign Off</button>
          </div>
        </div>
      </section>
    </div>
  `;
}

