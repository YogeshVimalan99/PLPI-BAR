        </table>

        ${
          labelRecord.printed
            ? `
              <div class="panel-title">Photo Evidence</div>
              <div class="evidence-upload-grid item-evidence-grid">
                ${(labelRecord.itemsPrinted || [])
                  .map(
                    (item) => `
                      <label>${item} - first photo <input type="file" data-label-evidence data-label-evidence-first data-evidence-item="${item}" accept="image/*"></label>
                      <label>${item} - last photo <input type="file" data-label-evidence data-label-evidence-last data-evidence-item="${item}" accept="image/*"></label>
