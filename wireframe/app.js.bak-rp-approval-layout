function updateBatchCheckerAvailability() {
  const genPclBtn = document.querySelector("#batchchecker-generate-pcl");
  const genPclColdBtn = document.querySelector("#batchchecker-generate-pcl-cold");
  const reprintLabelBtn = document.querySelector("#batchchecker-reprint-label");
  const batchCheckBtn = document.querySelector("#batchchecker-btn-check");
  const printBoxBtn = document.querySelector("#batchchecker-print-box");
  
  if (!genPclBtn) return;
  
  const hasSelected = selectedBatchCheckerRowKey !== null;
  const rows = getBatchCheckerRows();
  const selectedRow = hasSelected && selectedBatchCheckerRowKey < rows.length ? rows[selectedBatchCheckerRowKey] : null;
  
  const rowKey = selectedRow ? `${selectedRow.orderNo}_${selectedRow.batchNo}` : "";
  const isChecked = selectedRow && batchCheckerCheckedRows[rowKey] === true;
  const isVerified = selectedRow && (batchCheckerVerifiedRows[rowKey] || selectedRow.status === "BatchCheck" || selectedRow.status === "Printer");
  
  genPclBtn.disabled = !isChecked || !isVerified;
  genPclColdBtn.disabled = !isChecked || !isVerified;
  reprintLabelBtn.disabled = !isChecked;
  
  batchCheckBtn.disabled = !isChecked; // Disabled if the line is not selected/checked
  
  printBoxBtn.disabled = !isChecked || !isVerified;
}

