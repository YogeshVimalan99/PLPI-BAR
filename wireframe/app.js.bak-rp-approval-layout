function renderRpPackWork(stage) {
  if (Object.keys(rpPackWorkflows).length === 0) {
    rpPackWorkflows["C13719"] = {
      poNo: "C13719",
      status: "Pending Uploads",
      signoff: null,
      documents: [
        { id: "supplier-invoice", name: "Supplier invoice", required: true, uploaded: false, fileName: "" },
        { id: "po", name: "PO", required: true, uploaded: false, fileName: "" },
        { id: "supplier-packing-list", name: "Supplier packing list", required: true, uploaded: false, fileName: "" },
        { id: "supplier-declaration", name: "Supplier declaration", required: true, uploaded: false, fileName: "" },
        { id: "temperature-record", name: "Temperature record", required: true, uploaded: false, fileName: "" },
        { id: "goods-receiving-checklist", name: "Goods receiving checklist", required: true, uploaded: false, fileName: "" },
        { id: "delivery-details", name: "Delivery Details", required: true, uploaded: false, fileName: "" }
      ]
    };
  }
  const completedPoKeys = Object.keys(rpPackWorkflows).filter((poKey) => {
    const po = rpPackWorkflows[poKey];
    return po.status === "Signed Off" || po.signoff !== null || rpApprovalSignoffs[poKey] !== undefined;
  });

  if (completedPoKeys.length > 0 && (!selectedRpApprovalPo || !completedPoKeys.includes(selectedRpApprovalPo))) {
    selectedRpApprovalPo = completedPoKeys[0];
  } else if (completedPoKeys.length === 0) {
    selectedRpApprovalPo = null;
  }

  const poListHtml = completedPoKeys.length > 0
    ? completedPoKeys
        .map((poKey) => {
          const po = rpPackWorkflows[poKey];
          const isActive = poKey === selectedRpApprovalPo ? "active" : "";
          
          const isSignedOffByGoodsIn = po.status === "Signed Off" || po.signoff !== null;
          const isApprovedByRp = rpApprovalSignoffs[poKey] !== undefined;
          
          let displayStatus = "Pending Goods-In";
          let badgeClass = "pending-status";
          
          if (isApprovedByRp) {
            displayStatus = "Approved by RP";
            badgeClass = "done-status";
          } else if (isSignedOffByGoodsIn) {
            displayStatus = "Ready for RP Review";
            badgeClass = "active-status";
          }

          return `
            <div class="rp-po-card ${isActive}" data-rp-approval-select-po="${poKey}">
              <strong>${poKey}</strong>
              <span class="status ${badgeClass}">${displayStatus}</span>
            </div>
