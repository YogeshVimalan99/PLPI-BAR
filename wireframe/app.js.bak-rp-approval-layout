    const isApprovedByRp = rpApprovalSignoffs[selectedRpApprovalPo] !== undefined;
    const rpSignoff = rpApprovalSignoffs[selectedRpApprovalPo];

    const docListHtml = activePo.documents
      .map((doc, index) => {
        const fileStatus = doc.uploaded
          ? `<span class="rp-file-badge">${doc.fileName || "Uploaded.pdf"}</span>`
          : `<span class="rp-file-badge pending">Not Uploaded</span>`;
        
        const viewLink = doc.uploaded
          ? `<button class="classic-button link-button" type="button" data-rp-view-file="${doc.id}" data-rp-po="${activePo.poNo}">View</button>`
          : `<span class="disabled-text">N/A</span>`;

        return `
          <div class="rp-document-row">
            <span class="rp-doc-index">${String(index + 1).padStart(2, "0")}</span>
            <span class="rp-doc-name">${doc.name}<small>Uploaded by Goods-In</small></span>
            <div class="rp-file-upload-cell">
              ${fileStatus}
              ${viewLink}
            </div>
          </div>
        `;
      })
      .join("");

    const packingListRowHtml = `
      <div class="rp-document-row packing-list-row-document">
        <span class="rp-doc-index">08</span>
        <span class="rp-doc-name">Generated PO Packing List<small>Generated by PLPI</small></span>
