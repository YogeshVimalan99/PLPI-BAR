                    ${config.rowPrintPreview ? `<td><button class="classic-button row-print-button" type="button" data-preview-print data-preview-type="${config.type}" data-preview-batch="${product.batch}" data-preview-item="${item.label}" ${isPrintItemDone(record, item.label) ? "disabled" : ""}>Print</button></td>` : ""}
