        })
        .join("")
    : `<div style="padding: 10px; font-size: 11px; color: #666; font-style: italic;">No POs signed off by Goods-In yet.</div>`;

  const activePo = selectedRpApprovalPo ? rpPackWorkflows[selectedRpApprovalPo] : null;
  let mainContentHtml = "";

