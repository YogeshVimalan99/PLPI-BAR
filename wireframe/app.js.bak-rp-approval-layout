        </div>
      </div>
    `;

    const checksHtml = renderRpApprovalFormInteractive(activePo.poNo, isApprovedByRp, stage);

    mainContentHtml = `
      <div class="rp-documents-main">
        <div class="rp-documents-header">
          <div>
            <h3>RP Approval for PO ${activePo.poNo}</h3>
            <p>Review the uploaded Goods-In records and generated packing list before digital sign off.</p>
          </div>
          <span>${isApprovedByRp ? `Approved by ${rpSignoff.user}` : isSignedOffByGoodsIn ? "Pending RP Approval" : "Pending Goods-In Uploads"}</span>
        </div>
        <div class="rp-documents-list">
          ${docListHtml}
          ${packingListRowHtml}
        </div>
        <div style="max-height: 480px; overflow-y: auto; border: 1px solid #ccc; border-radius: 4px; margin: 15px 0; background: #fafafa;">
          ${checksHtml}
