    statusMessage.textContent = "Enter specimen, leaflet fold, and tamper seal counts.";
  } else if (preAssemblySelectedProduct.routeType === "Reboxing" && !packSizeFormValid) {
    statusMessage.textContent = "Digitally sign the Change of Pack Size form as Pre-Assembly Quality Checker.";
  } else {
