    if (changeOfPackSizeData[batch]) {
      if (section === "receivedAs" || section === "assembledAs") {
changeOfPackSizeData[batch][section].initials = "";
      } else {
changeOfPackSizeData[batch][section + "Initials"] = "";
      }
      
