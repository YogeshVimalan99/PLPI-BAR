  min-height: 0;
  background-color: #a0a0a0 !important;
}

.mdi-area {
  background: #a0a0a0 !important;
  border-right: 1px solid #808080;
  min-height: 0;
  overflow: auto;
  padding: 18px;
  position: relative;
}

.right-launcher {
  align-content: start;
  background: #ffffff;
  border-left: 1px solid #d0d0d0;
  box-shadow: none;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px 8px;
  overflow-y: auto;
  padding: 10px 8px;
  width: 220px;
}

.launcher-item {
  align-items: center;
