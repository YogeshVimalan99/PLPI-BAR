:root {
  --title-start: #3a7ebb;
  --title-end: #7daed6;
  --classic-blue: #3a7ebb;
  --classic-blue-dark: #07598d;
  --desktop-grey: #a0a0a0;
  --panel: #f0f0f0;
  --panel-dark: #d0d0d0;
  --border-dark: #808080;
  --border-light: #ffffff;
  --text: #000000;
  --muted: #555555;
  --success: #385723;
  --warning: #c65911;
  --danger: #c21f1f;
}

* {
  box-sizing: border-box;
}

html,
body {
  margin: 0;
  min-height: 100%;
}

body {
  background: #a0a0a0;
  color: var(--text);
  font-family: Tahoma, "MS Sans Serif", "Segoe UI", Arial, sans-serif;
  font-size: 13.5px;
  letter-spacing: 0;
}

button,
input,
select {
  font: inherit;
}

button {
  cursor: pointer;
}

.plpi-app {
  display: grid;
  grid-template-rows: 24px 68px minmax(0, 1fr) 22px;
  height: 100vh;
  min-width: 1180px;
}

.pre-login .plpi-app {
  grid-template-rows: 24px minmax(0, 1fr) 22px;
}

.pre-login .top-toolbar,
.pre-login .right-launcher {
  display: none;
}

.pre-login .desktop {
  grid-template-columns: minmax(0, 1fr);
}

.window-title {
  align-items: center;
  background: linear-gradient(90deg, #2d6ca4 0%, #3a7ebb 40%, #7daed6 100%);
  border-bottom: 1px solid #1a446c;
  color: #fff;
  display: flex;
  justify-content: space-between;
  padding: 2px 8px;
}

.title-left {
  align-items: center;
  display: flex;
  gap: 5px;
  min-width: 0;
  font-weight: bold;
}

.app-badge {
  background: #0b98d4;
  border: 1px solid #056b98;
  color: #fff;
  display: inline-block;
  font-size: 10px;
  font-weight: 700;
  line-height: 16px;
  text-align: center;
  width: 18px;
}

.window-controls {
  display: flex;
  gap: 14px;
  font-size: 13px;
  font-weight: bold;
  cursor: pointer;
}

.top-toolbar {
  background: #fdfdfd;
  border-bottom: 1px solid #d0d0d0;
  display: flex;
  gap: 6px;
  overflow-x: auto;
  padding: 4px 8px;
  white-space: nowrap;
}

.toolbar-item {
  align-items: center;
  background: transparent;
  border: 1px solid transparent;
  border-radius: 3px;
  color: #333;
  display: flex;
  flex-direction: column;
  gap: 4px;
  justify-content: center;
  min-width: 80px;
  padding: 4px 6px;
  font-size: 11px;
  font-weight: 500;
}

.toolbar-item:hover {
  background: #f0f4f8;
  border-color: #c0d0e0;
  color: #000;
}

.toolbar-item.active {
  background: #e2effa;
  border-color: #a0c2e2;
  color: #0b5894;
  font-weight: bold;
}

.toolbar-icon,
.launcher-icon {
  border: 1px solid #777;
  border-radius: 4px;
  display: inline-block;
  height: 32px;
  position: relative;
  width: 32px;
  box-shadow: inset 1px 1px 0 #fff, 1px 1px 2px rgba(0,0,0,0.1);
}

.toolbar-icon::before,
.launcher-icon::before {
  align-items: center;
  color: #111;
  display: flex;
  font-size: 17px;
  font-weight: 700;
  height: 100%;
  justify-content: center;
  width: 100%;
}

