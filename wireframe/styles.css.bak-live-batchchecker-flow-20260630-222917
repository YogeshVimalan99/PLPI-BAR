  justify-content: space-between;
  padding: 4px 10px !important;
  font-size: 11px !important;
  color: #333333 !important;
  box-shadow: inset 0 1px 0 #ffffff;
}

.welcome-window,
.internal-window,
.login-window {
  background: #f4f4f4 !important;
  border: 3px solid #3a7ebb !important;
  border-radius: 4px 4px 0 0;
  box-shadow: 4px 4px 10px rgba(0, 0, 0, 0.35) !important;
  outline: 1px solid #ffffff;
  outline-offset: -3px;
}

.welcome-window {
  margin: 22px auto;
  max-width: 1050px;
}

.internal-window {
  min-width: 980px;
}

.module-window {
  min-width: 1180px;
}

.internal-title {
  align-items: center;
  background: linear-gradient(90deg, #2d6ca4 0%, #3a7ebb 40%, #7daed6 100%) !important;
  border-bottom: 1px solid #1a446c !important;
  color: #ffffff !important;
  display: flex;
  font-family: "Segoe UI", Tahoma, sans-serif;
  font-size: 13px !important;
